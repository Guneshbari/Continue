# Continue — Environment Variables Reference
# Copy to .env.local for development

# ─── Database ───────────────────────────────────────────
DATABASE_URL="postgresql://continue:continue@localhost:5432/continue_dev"
POSTGRES_USER="continue"
POSTGRES_PASSWORD="change-me"
POSTGRES_DB="continue"

# ─── Redis ──────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD="change-me"

# ─── Auth (JWT) ─────────────────────────────────────────
JWT_SECRET="replace-with-at-least-32-random-characters"
JWT_REFRESH_SECRET="replace-with-another-32-random-characters"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── API ────────────────────────────────────────────────
API_PORT=3001
API_PREFIX="/api/v1"
CORS_ORIGINS="http://localhost:3000"
AUTO_SEED_DATABASE="false"

# ─── Frontend ───────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Storage (future) ───────────────────────────────────
# STORAGE_PROVIDER="local"
# S3_BUCKET=""
# S3_REGION=""

# ─── Monitoring ─────────────────────────────────────────
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""

# ─── Firebase (Mocked) ──────────────────────────────────
FIREBASE_PROJECT_ID="mock-project-id"
FIREBASE_CLIENT_EMAIL="mock-client-email@mock.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC3...\n-----END PRIVATE KEY-----\n"
