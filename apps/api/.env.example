DATABASE_URL="postgresql://continue:continue@localhost:5432/continue_dev"

REDIS_URL="redis://localhost:6379"

JWT_SECRET="replace-with-at-least-32-random-characters"
JWT_REFRESH_SECRET="replace-with-another-32-random-characters"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

API_PORT=3001
CORS_ORIGINS="http://localhost:3000"

# Set to true on first run to populate the database with seed data
AUTO_SEED_DATABASE="false"

# Discovery Shelf Ranking Weights and Limits
DISCOVERY_TRENDING_RECENCY_DECAY=1.5
DISCOVERY_TOP_RATED_MIN_REVIEWS=1
DISCOVERY_HIDDEN_GEMS_MAX_REVIEWS=10
DISCOVERY_SHELF_DEFAULT_LIMIT=12

# Firebase Admin Integration
FIREBASE_PROJECT_ID="mock-project-id"
FIREBASE_CLIENT_EMAIL="mock-client-email@mock.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC3...\n-----END PRIVATE KEY-----\n"
