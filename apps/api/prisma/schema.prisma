// Continue Platform — Prisma Schema
// Phase 1: Core entity definitions. Migrations run in Phase 2+.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum ReviewStatus {
  PUBLISHED
  DRAFT
  REMOVED
}

enum ListVisibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  email        String    @unique
  passwordHash String    @map("password_hash")
  displayName  String?   @map("display_name")
  bio          String?
  avatarUrl    String?   @map("avatar_url")
  role         UserRole  @default(USER)
  isVerified   Boolean   @default(false) @map("is_verified")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  reviews       Review[]
  ratings       Rating[]
  lists         List[]
  refreshTokens RefreshToken[]

  @@index([deletedAt])
  @@index([role])
  @@map("users")
}

// ─── Game ────────────────────────────────────────────────────────────────────

model Game {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  description String?
  coverUrl    String?   @map("cover_url")
  bannerUrl   String?   @map("banner_url")
  releaseDate DateTime? @map("release_date")
  developer   String?
  publisher   String?
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  platforms GamePlatform[]
  genres    GameGenre[]
  tags      GameTag[]
  reviews   Review[]
  ratings   Rating[]
  listItems ListItem[]

  // Denormalized avg rating — updated by trigger/job
  avgRating   Float? @map("avg_rating")
  ratingCount Int    @default(0) @map("rating_count")

  @@index([deletedAt])
  @@index([title])
  @@index([releaseDate])
  @@index([ratingCount])
  @@index([avgRating])
  @@map("games")
}

// ─── Platform ────────────────────────────────────────────────────────────────

model Platform {
  id    String @id @default(cuid())
  slug  String @unique
  name  String
  games GamePlatform[]

  @@map("platforms")
}

model GamePlatform {
  gameId     String @map("game_id")
  platformId String @map("platform_id")
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  platform   Platform @relation(fields: [platformId], references: [id])

  @@id([gameId, platformId])
  @@index([platformId])
  @@map("game_platforms")
}

// ─── Genre ───────────────────────────────────────────────────────────────────

model Genre {
  id    String @id @default(cuid())
  slug  String @unique
  name  String
  games GameGenre[]

  @@map("genres")
}

model GameGenre {
  gameId  String @map("game_id")
  genreId String @map("genre_id")
  game    Game  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  genre   Genre @relation(fields: [genreId], references: [id])

  @@id([gameId, genreId])
  @@index([genreId])
  @@map("game_genres")
}

// ─── Tag ─────────────────────────────────────────────────────────────────────

model Tag {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  approved  Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at")
  games     GameTag[]

  @@index([approved])
  @@map("tags")
}

model GameTag {
  gameId String @map("game_id")
  tagId  String @map("tag_id")
  game   Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id])

  @@id([gameId, tagId])
  @@index([tagId])
  @@map("game_tags")
}

// ─── Review ──────────────────────────────────────────────────────────────────

model Review {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  gameId    String       @map("game_id")
  title     String?
  body      String
  status    ReviewStatus @default(PUBLISHED)
  isPrimary Boolean      @default(true) @map("is_primary")
  isSpoiler Boolean      @default(false) @map("is_spoiler")
  deletedAt DateTime?    @map("deleted_at")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])
  game Game @relation(fields: [gameId], references: [id])

  // One primary review per user per game
  @@unique([userId, gameId, isPrimary])
  @@index([deletedAt])
  @@index([gameId, status])
  @@index([userId, status])
  @@map("reviews")
}

// ─── Rating ──────────────────────────────────────────────────────────────────

model Rating {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  gameId    String   @map("game_id")
  score     Int      // 1-10
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])
  game Game @relation(fields: [gameId], references: [id])

  // One rating per user per game
  @@unique([userId, gameId])
  @@index([gameId])
  @@index([score])
  @@map("ratings")
}

// ─── List ────────────────────────────────────────────────────────────────────

model List {
  id          String         @id @default(cuid())
  userId      String         @map("user_id")
  slug        String
  title       String
  description String?
  visibility  ListVisibility @default(PUBLIC)
  deletedAt   DateTime?      @map("deleted_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  user  User       @relation(fields: [userId], references: [id])
  items ListItem[]

  @@unique([userId, slug])
  @@index([deletedAt])
  @@index([userId, visibility])
  @@map("lists")
}

model ListItem {
  id        String   @id @default(cuid())
  listId    String   @map("list_id")
  gameId    String   @map("game_id")
  position  Int      @default(0)
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  list List @relation(fields: [listId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id])

  @@unique([listId, gameId])
  @@index([gameId])
  @@index([listId, position])
  @@map("list_items")
}

// ─── Refresh Token ────────────────────────────────────────────────────────────
// Stored hashed. Invalidated on use (rotation) and on logout.

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}
