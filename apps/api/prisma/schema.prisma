// Continue Platform — Prisma Schema
// Phase 1: Core entity definitions. Migrations run in Phase 2+.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum ReviewStatus {
  PUBLISHED
  DRAFT
  REMOVED
}

enum ListVisibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

enum MediaRole {
  COVER_SM
  COVER_MD
  COVER_LG
  BACKDROP_HERO
  GALLERY_HD
  THUMBNAIL_BLUR
  AVATAR_SM
  AVATAR_MD
  LOGO_TRANSPARENT
}

enum MediaProcessingState {
  PENDING
  PROCESSING
  READY
  FAILED
}



// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  email        String    @unique
  passwordHash String?   @map("password_hash")
  firebaseUid  String?   @unique @map("firebase_uid")
  displayName  String?   @map("display_name")
  bio          String?
  avatarUrl    String?   @map("avatar_url")
  role         UserRole  @default(USER)
  isVerified   Boolean   @default(false) @map("is_verified")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  reviews       Review[]
  ratings       Rating[]
  lists         List[]
  refreshTokens RefreshToken[]

  @@index([deletedAt])
  @@index([role])
  @@map("users")
}

// ─── Game ────────────────────────────────────────────────────────────────────

model Game {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  description     String?
  releaseDate     DateTime? @map("release_date")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  igdbId          Int?      @unique @map("igdb_id")
  summary         String?   @db.Text
  storyline       String?   @db.Text
  igdbRating      Float?    @map("igdb_rating")
  igdbRatingCount Int?      @map("igdb_rating_count")
  status          String?   // "released", "alpha", "announced"
  franchiseId     String?   @map("franchise_id")
  franchise       Franchise? @relation(fields: [franchiseId], references: [id])

  coverId         String?   @map("cover_id")
  backdropId      String?   @map("backdrop_id")
  cover           MediaAsset? @relation("GameCover", fields: [coverId], references: [id])
  backdrop        MediaAsset? @relation("GameBackdrop", fields: [backdropId], references: [id])

  platforms   GamePlatform[]
  genres      GameGenre[]
  tags        GameTag[]
  reviews     Review[]
  ratings     Rating[]
  listItems   ListItem[]
  screenshots Screenshot[]
  trailers    Trailer[]
  themes      GameTheme[]
  developers  GameDeveloper[]
  publishers  GamePublisher[]

  // Denormalized avg rating — updated by trigger/job
  avgRating   Float? @map("avg_rating")
  ratingCount Int    @default(0) @map("rating_count")

  @@index([deletedAt])
  @@index([title])
  @@index([releaseDate])
  @@index([ratingCount])
  @@index([avgRating])
  @@map("games")
}



// ─── Platform ────────────────────────────────────────────────────────────────

model Platform {
  id    String @id @default(cuid())
  slug  String @unique
  name  String
  games GamePlatform[]

  @@map("platforms")
}

model GamePlatform {
  gameId     String @map("game_id")
  platformId String @map("platform_id")
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  platform   Platform @relation(fields: [platformId], references: [id])

  @@id([gameId, platformId])
  @@index([platformId])
  @@map("game_platforms")
}

// ─── Media Assets ────────────────────────────────────────────────────────────

model MediaAsset {
  id                        String               @id @default(cuid())
  rawUrl                    String               @map("raw_url")
  hash                      String?              @unique
  optimized                 Boolean              @default(false)
  processingState           MediaProcessingState @default(PENDING) @map("processing_state")
  retryCount                Int                  @default(0) @map("retry_count")
  lastFailureReason         String?              @map("last_failure_reason")
  lastProcessedAt           DateTime?            @map("last_processed_at")
  processingDurationMs      Int?                 @map("processing_duration_ms")
  localOriginalPath         String?              @map("local_original_path")
  transformationFingerprint String?              @map("transformation_fingerprint")
  createdAt                 DateTime             @default(now()) @map("created_at")
  updatedAt                 DateTime             @updatedAt @map("updated_at")
  
  variants      MediaVariant[]
  coverGames    Game[]         @relation("GameCover")
  backdropGames Game[]         @relation("GameBackdrop")
  screenshots   Screenshot[]

  @@map("media_assets")
}

model MediaVariant {
  id              String     @id @default(cuid())
  assetId         String     @map("asset_id")
  asset           MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  role            MediaRole
  url             String
  width           Int?
  height          Int?
  format          String
  blurPlaceholder String?    @map("blur_placeholder")
  createdAt       DateTime   @default(now()) @map("created_at")

  @@unique([assetId, role, format])
  @@index([assetId])
  @@map("media_variants")
}


// ─── Genre ───────────────────────────────────────────────────────────────────

model Genre {
  id    String @id @default(cuid())
  slug  String @unique
  name  String
  games GameGenre[]

  @@map("genres")
}

model GameGenre {
  gameId  String @map("game_id")
  genreId String @map("genre_id")
  game    Game  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  genre   Genre @relation(fields: [genreId], references: [id])

  @@id([gameId, genreId])
  @@index([genreId])
  @@map("game_genres")
}

// ─── Tag ─────────────────────────────────────────────────────────────────────

model Tag {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  approved  Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at")
  games     GameTag[]

  @@index([approved])
  @@map("tags")
}

model GameTag {
  gameId String @map("game_id")
  tagId  String @map("tag_id")
  game   Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id])

  @@id([gameId, tagId])
  @@index([tagId])
  @@map("game_tags")
}

// ─── Review ──────────────────────────────────────────────────────────────────

model Review {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  gameId    String       @map("game_id")
  title     String?
  body      String
  status    ReviewStatus @default(PUBLISHED)
  isPrimary Boolean      @default(true) @map("is_primary")
  isSpoiler Boolean      @default(false) @map("is_spoiler")
  deletedAt DateTime?    @map("deleted_at")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])
  game Game @relation(fields: [gameId], references: [id])

  // One primary review per user per game
  @@unique([userId, gameId, isPrimary])
  @@index([deletedAt])
  @@index([gameId, status])
  @@index([userId, status])
  @@map("reviews")
}

// ─── Rating ──────────────────────────────────────────────────────────────────

model Rating {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  gameId    String   @map("game_id")
  score     Int      // 1-10
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])
  game Game @relation(fields: [gameId], references: [id])

  // One rating per user per game
  @@unique([userId, gameId])
  @@index([gameId])
  @@index([score])
  @@map("ratings")
}

// ─── List ────────────────────────────────────────────────────────────────────

model List {
  id          String         @id @default(cuid())
  userId      String         @map("user_id")
  slug        String
  title       String
  description String?
  visibility  ListVisibility @default(PUBLIC)
  deletedAt   DateTime?      @map("deleted_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  user  User       @relation(fields: [userId], references: [id])
  items ListItem[]

  @@unique([userId, slug])
  @@index([deletedAt])
  @@index([userId, visibility])
  @@map("lists")
}

model ListItem {
  id        String   @id @default(cuid())
  listId    String   @map("list_id")
  gameId    String   @map("game_id")
  position  Int      @default(0)
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  list List @relation(fields: [listId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id])

  @@unique([listId, gameId])
  @@index([gameId])
  @@index([listId, position])
  @@map("list_items")
}

// ─── Refresh Token ────────────────────────────────────────────────────────────
// Stored hashed. Invalidated on use (rotation) and on logout.

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─── Additional Relational Metadata ──────────────────────────────────────────

model Screenshot {
  id        String     @id @default(cuid())
  gameId    String     @map("game_id")
  game      Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  assetId   String     @map("asset_id")
  asset     MediaAsset @relation(fields: [assetId], references: [id])
  position                Int        @default(0)
  heroScore               Float?     @map("hero_score")
  isPrimaryHeroCandidate  Boolean    @default(false) @map("is_primary_hero_candidate")
  createdAt               DateTime   @default(now()) @map("created_at")

  @@index([gameId])
  @@map("screenshots")
}

model Trailer {
  id        String   @id @default(cuid())
  gameId    String   @map("game_id")
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  youtubeId String   @map("youtube_id")
  name      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([gameId])
  @@map("trailers")
}

model Franchise {
  id    String @id @default(cuid())
  slug  String @unique
  name  String
  games Game[]

  @@map("franchises")
}

model Theme {
  id    String @id @default(cuid())
  slug  String @unique
  name  String
  games GameTheme[]

  @@map("themes")
}

model GameTheme {
  gameId  String @map("game_id")
  themeId String @map("theme_id")
  game    Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  theme   Theme  @relation(fields: [themeId], references: [id])

  @@id([gameId, themeId])
  @@index([themeId])
  @@map("game_themes")
}

model Developer {
  id    String @id @default(cuid())
  slug  String @unique
  name  String
  games GameDeveloper[]

  @@map("developers")
}

model GameDeveloper {
  gameId      String    @map("game_id")
  developerId String    @map("developer_id")
  game        Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  developer   Developer @relation(fields: [developerId], references: [id])

  @@id([gameId, developerId])
  @@index([developerId])
  @@map("game_developers")
}

model Publisher {
  id    String @id @default(cuid())
  slug  String @unique
  name  String
  games GamePublisher[]

  @@map("publishers")
}

model GamePublisher {
  gameId      String    @map("game_id")
  publisherId String    @map("publisher_id")
  game        Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  publisher   Publisher @relation(fields: [publisherId], references: [id])

  @@id([gameId, publisherId])
  @@index([publisherId])
  @@map("game_publishers")
}

